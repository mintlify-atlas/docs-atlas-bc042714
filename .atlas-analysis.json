  "keyFeatures": [
    "Custom Windows 11 themes (light, dark, black, partial-dark) with UxTheme patcher",
    "System icon patching for hundreds of Windows UI elements",
    "Mica For Everyone integration for translucent window effects",
    "Enhanced context menu via Nilesoft Shell (multiple styles)",
    "AccentColorizer for dynamic accent color support",
    "Windows Gadgets revival via GadgetPack",
    "Custom wallpapers and user account avatars",
    "Two-phase installation using TrustedInstaller privileges",
    "Automatic system restore point creation before installation",
    "Full uninstaller with backup/restore of original files",
    "Multi-language support (23 languages)",
    "Rectify11 Control Panel for post-install management"
  ],
